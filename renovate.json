{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Acompanha a versao do Threadfin no build.yaml e no Dockerfile",
      "fileMatch": [
        "threadfin/build\\.yaml$",
        "threadfin/Dockerfile$"
      ],
      "matchStrings": [
        "fyb3roptik/threadfin:(?<currentValue>[0-9][0-9.]+)"
      ],
      "depNameTemplate": "fyb3roptik/threadfin",
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Espelha a versao do add-on (config.yaml) na do Threadfin para o HA mostrar a atualizacao",
      "fileMatch": [
        "threadfin/config\\.yaml$"
      ],
      "matchStrings": [
        "version:\\s*\"(?<currentValue>[0-9][0-9.]+)\""
      ],
      "depNameTemplate": "fyb3roptik/threadfin",
      "datasourceTemplate": "docker"
    }
  ]
}
